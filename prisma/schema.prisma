datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id                 String      @id @default(cuid())
  name               String?
  email              String      @unique
  emailVerified      DateTime?
  image              String?
  googleAccessToken  String?
  googleRefreshToken String?
  accounts           Account[]
  sessions           Session[]
  preferences        Preference?
  tasks              Task[]
  schedules          Schedule[]
  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Preference {
  id               String   @id @default(cuid())
  userId           String   @unique
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  workStart        String   @default("09:00") // e.g. "09:00"
  workEnd          String   @default("18:00") // e.g. "18:00"
  daysOff          String   @default("Saturday,Sunday") // comma separated days
  bufferMinutes    Int      @default(15)
  maxFocusBlockMin Int      @default(120)
  chronotype       String   @default("flexible") // morning, evening, night, flexible
  peakStart        String   @default("09:00") // e.g. "09:00"
  peakEnd          String   @default("12:00") // e.g. "12:00"
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model Task {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  title       String
  durationMin Int
  deadline    DateTime?
  priority    Int       @default(3) // 1 (highest) - 5 (lowest)
  category    String    @default("Work") // Work, Personal, Study, Health
  constraints String?   // free text e.g. "mornings only"
  status      String    @default("pending") // pending, scheduled, done
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Schedule {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  weekOf     DateTime
  blocksJson String   // JSON string of array of { id, taskId, title, category, start, end, googleEventId, isSynced }
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}
